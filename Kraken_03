#!/usr/bin/env bash
#SBATCH --job-name=kraken3.1
#SBATCH --output=logs/krak_%a.out
#SBATCH --error=logs/krak_%a.err
#SBATCH --time=24:00:00
#SBATCH --mem=64G
#SBATCH --cpus-per-task=32
#SBATCH --array=0-5

set -euo pipefail

module load kraken2

SAMPLES=(raw/SRR*/*.sra)
FASTQ_DIR="metagenomics_output"
KRAKEN_DIR="kraken_output"

SAMPLE="${SAMPLES[$SLURM_ARRAY_TASK_ID]}"
NAME=$(basename "${SAMPLE}" .sra)

R1="${FASTQ_DIR}/${NAME}/${NAME}_1.fastq.gz"
R2="${FASTQ_DIR}/${NAME}/${NAME}_2.fastq.gz"
CLASSDIR="${KRAKEN_DIR}/${NAME}/classification"

mkdir -p "${CLASSDIR}"

echo "Sample: ${NAME}"
echo "R1: ${R1}"
echo "R2: ${R2}"

# Check input files exist
if [[ ! -f "${R1}" ]]; then
    echo "ERROR: Missing R1 file: ${R1}"
    exit 1
fi

if [[ ! -f "${R2}" ]]; then
    echo "ERROR: Missing R2 file: ${R2}"
    exit 1
fi

# Check gzip integrity
if ! gunzip -t "${R1}"; then
    echo "ERROR: Corrupted R1 gzip file: ${R1}"
    exit 1
fi

if ! gunzip -t "${R2}"; then
    echo "ERROR: Corrupted R2 gzip file: ${R2}"
    exit 1
fi

# Run Kraken2 on paired-end reads
kraken2 \
    --db kraken_db \
    --confidence 0.15 \
    --paired \
    --threads 32 \
    --output "${CLASSDIR}/${NAME}.kraken" \
    --report "${CLASSDIR}/${NAME}.report" \
    "${R1}" "${R2}"
